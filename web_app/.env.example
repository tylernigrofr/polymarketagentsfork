# Polymarket AI Predictions Web App
# Copy this file to .env and fill in your actual API keys

# NOT REQUIRED - Market data uses Gamma API (no authentication needed)
# POLYGON_WALLET_PRIVATE_KEY=your_polygon_wallet_private_key_here

# Required for AI predictions (choose one or both)
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional - enhances news and search features
TAVILY_API_KEY=your_tavily_api_key_here
NEWSAPI_API_KEY=your_newsapi_key_here

# Application settings
ENVIRONMENT=development
DEBUG=true

# Configuration flags
USE_REAL_DATA=true
DEFAULT_MODEL=anthropic/claude-3-haiku